# Claude Code Telegrammer — Environment Variables
# Copy to .env and fill in your values
#
# Naming: every variable below is read through lib/env.ts::getenv(), which
# accepts THREE spellings of the same setting (mirrors SAC's SAC_ /
# SCITEX_AGENT_CONTAINER_ pair):
#
#   CCT_<KEY>                              short alias  (preferred — cleanest)
#   CLAUDE_CODE_TELEGRAMMER_<KEY>          canonical / long form
#   CLAUDE_CODE_TELEGRAMMER_TELEGRAM_<KEY> legacy (deprecated, still honoured)
#
# Pick ONE spelling per variable. If two are set to DIFFERENT values the
# server fails loud at startup (no silent fallback). The examples below use
# the canonical form; the CCT_ equivalent is shown in a comment.
#
# Note: this MCP server uses getUpdates long-polling to receive Telegram
# messages. For webhook mode (no polling conflicts), use scitex-orochi:
#   https://github.com/ywatanabe1989/scitex-orochi

# Required: Telegram bot token from @BotFather        (alias: CCT_BOT_TOKEN)
CLAUDE_CODE_TELEGRAMMER_BOT_TOKEN=123456789:AAH...

# Required: Comma-separated Telegram user IDs allowed  (alias: CCT_ALLOWED_USERS)
CLAUDE_CODE_TELEGRAMMER_ALLOWED_USERS=YOUR_TELEGRAM_USER_ID

# Optional: State directory (default: ~/.claude-code-telegrammer)
#                                                      (alias: CCT_STATE_DIR)
CLAUDE_CODE_TELEGRAMMER_STATE_DIR=~/.claude-code-telegrammer

# Optional: Hostname for message metadata (default: os.hostname())
#                                                      (alias: CCT_HOST_NAME)
CLAUDE_CODE_TELEGRAMMER_HOST_NAME=

# Optional: Project identifier for message metadata (default: cwd)
#                                                      (alias: CCT_PROJECT)
CLAUDE_CODE_TELEGRAMMER_PROJECT=

# Optional: Agent ID for message metadata (default: 'telegram')
#                                                      (alias: CCT_AGENT_ID)
CLAUDE_CODE_TELEGRAMMER_AGENT_ID=

# Optional: Two-stage read-receipt reactions on inbound messages (default: on).
# ⚡ is added when the relay receives the message, then 👀 when it is surfaced
# into the Claude session. Set to 0/false/no/off to disable.
#                                                      (alias: CCT_READ_RECEIPTS)
CLAUDE_CODE_TELEGRAMMER_READ_RECEIPTS=on
