# Orochi Head Agent (ywata-note-win) -- agent-container definition
# Launched via: scitex-orochi launch head ywata-note-win
# Auto-discovered from ~/.scitex/orochi/agents/head-ywata-note-win/
apiVersion: cld-agent/v1
kind: Agent
metadata:
  name: head-ywata-note-win
  labels:
    role: head
    team: orochi
    machine: ywata-note-win
    capabilities: development,testing,git
spec:
  runtime: claude-code
  model: "opus[1m]"
  # Each agent gets an isolated workspace. agent-container auto-generates
  # .mcp.json here from the orochi config below.
  workdir: ~/.scitex/orochi/workspaces/head-ywata-note-win

  claude:
    channels: []
    flags:
      - --dangerously-skip-permissions
      - "--dangerously-load-development-channels server:scitex-orochi"
    # Fresh session each launch — --continue has no prior session in the
    # isolated workspace dir, so it would crash.
    session: new

  skills:
    required:

