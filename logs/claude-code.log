# Orochi Deployment Configuration
# Generated by: scitex-orochi init
# Documentation: https://github.com/ywatanabe1989/scitex-orochi
#
# This file configures the Orochi agent network. All hostnames, ports,
# and credentials are read from this file -- nothing is hardcoded.

orochi:
  # Environment selection: stable | dev
  # Controls which server config block is used for CLI operations.
  environment: stable

  server:
    # WebSocket server location (where orochi-server runs)
    host: 192.168.11.22

    # Stable instance (production -- never break)
    # Django ASGI serves both HTTP and WebSocket on the same port (8559)
    stable:
      ws_port: 8559
      dashboard_port: 8559
      domain: scitex-lab.scitex-orochi.com

    # Dev instance (development -- break freely)
    dev:
      ws_port: 8560
      dashboard_port: 8560
      domain: orochi-dev.scitex.ai

    # Legacy flat fields (used when environment is not set)
    ws_port: 8559
    dashboard_port: 8559
    domain: orochi.example.com

  master:
    # The orchestrator agent -- receives user messages, delegates to heads
    # Name format: orochi-agent:<role>:<user>@<host>
    host: ywata-note-win
    user: ywatanabe  # defaults to current unix user if omitted
    model: opus[1m]
    channels: ["#general", "#orchestrator"]

  heads:
    # Each head runs on a specific machine, executing tasks delegated by master
    # Name format: orochi-agent:head:<user>@<host>
    - ssh: "ssh server1"
      host: server1
      user: ywatanabe
      model: opus[1m]
      channels: ["#general", "#deploy"]
      workdir: ~/proj

    - ssh: "ssh gpu-box"
      host: gpu-box
      user: ywatanabe
      model: sonnet
      channels: ["#general", "#research"]
      workdir: ~/proj

  # Agent Container Integration (recommended)
  # Agent YAML definitions live in ~/.scitex/orochi/agents/ (per-user).
  # The repo ships example definitions under examples/agents/ as reference.
  # No --agent-config flag needed -- just run:
  #   scitex-orochi launch master        # discovers ~/.scitex/orochi/agents/master*.yaml
  #   scitex-orochi launch head general  # discovers head-general*.yaml
  #   scitex-orochi launch all           # discovers all YAMLs
  #
  # Install: pip install scitex-orochi[agent-container]
  #
  # Falls back to the master/heads sections above if agent-container is
  # not installed or no YAML files are found.
  agents:
    directory: ~/.scitex/orochi/agents   # Per-user agent definitions
    examples: ./examples/agents          # Example definitions shipped with repo
    master: master.yaml
    heads:
      - head-general.yaml
      - head-research.yaml
      - head-deploy.yaml

  # Telegram bridge: orochi-server owns the bot token as a singleton.
  # User messages arrive via Telegram -> orochi-server -> #telegram channel.
  # Master agent replies by posting to #telegram -> orochi-server -> Telegram.
  telegram:
    enabled: true
    bot_token_env: SCITEX_OROCHI_TELEGRAM_BOT_
