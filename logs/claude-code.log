# Orochi Head Agent (ywata-note-win) -- agent-container definition
# Launched via: scitex-orochi launch head ywata-note-win
# Auto-discovered from ~/.scitex/orochi/agents/head-ywata-note-win/
apiVersion: cld-agent/v1
kind: Agent
metadata:
  name: head-ywata-note-win
  labels:
    role: head
    team: orochi
    machine: ywata-note-win
    capabilities: development,testing,git
spec:
  runtime: claude-code
  model: "opus[1m]"
  # Each agent gets an isolated workspace. agent-container auto-generates
  # .mcp.json here from the orochi config below.
  workdir: ~/.scitex/orochi/workspaces/head-ywata-note-win

  claude:
    channels: []
    flags:
      - --dangerously-skip-permissions
      - "--dangerously-load-development-channels server:scitex-orochi"
    # Fresh session each launch — --continue has no prior session in the
    # isolated workspace dir, so it would crash.
    session: new

  skills:
    required:
      - python-scitex   # General purpose scientific computing

  orochi:
    enabled: true
    hosts:
      - 192.168.11.22        # MBA LAN (fast)
      - scitex-orochi.com    # domain (fallback)
    port: 8559
    token_env: SCITEX_OROCHI_TOKEN
    channels:
      - "#general"
    heartbeat_interval: 60

  env:
    # SCITEX_OROCHI_HOST/PORT/TOKEN come from ~/.bash.d/secrets/010_scitex/01_orochi.src
    SCITEX_OROCHI_AGENT: head-ywata-note-win
    # Explicitly clear SCITEX_OROCHI_DISABLE so the bun mcp_channel.ts
    # zero-trust guard doesn't block this non-telegrammer session
    # (the env var is inherited from the telegrammer's shell when
    # scitex-orochi launch is run from there).
    SCITEX_OROCHI_DISABLE: ""
    SCITEX_OROCHI_CHANNELS: "#general"
    SCITEX_OROCHI_MODEL: "Opus 4.6 (1M)"
    CLAUDE_AGENT_ROLE: head
    CLAUDE_AGENT_ID: head-ywata-note-win

  screen:
    name: head-ywata-note-win

  health:
    enabled: true
    interval: 60
    timeout: 5
    method: screen-alive

  restart:
    policy: on-failure
    max_retries: 3
    backoff:
      initial: 30
      max: 300
      multiplier: 2

  hooks:
    pre_start:
      - "mkdir -p ~/.scitex/orochi/workspaces/head-ywata-note-win/.claude"
    post_start: []
    pre_stop: []
    post_stop: []

  startup_commands:
    - delay: 5
      command: "You are head-ywata-note-win, a general head agent in the Orochi fleet running on the ywata-note-win (WSL) machine. Your role: handle local development tasks, testing, git operations. Post to #general announcing you are online and ready to take tasks. Then idle — channel messages will arrive as <channel> tags pushed by the scitex-orochi MCP server in real time."

