# Orochi Stable Instance (Production) — Django + Daphne
# Port: 8559 (HTTP + WebSocket via ASGI)
# Volume: /data/orochi-stable/

services:
  orochi:
    build:
      context: ../..
      dockerfile: deployment/docker/Dockerfile
    container_name: orochi-server-stable
    ports:
      - "8559:8559"
    volumes:
      - /data/orochi-stable:/data
    environment:
      - DJANGO_SECRET_KEY=${DJANGO_SECRET_KEY:-change-me-in-production}
      - DJANGO_DEBUG=false
      - DJANGO_ALLOWED_HOSTS=.scitex-orochi.com,localhost
