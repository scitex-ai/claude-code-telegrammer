# scitex-dev CI runner container (CPU) — Apptainer recipe (public SSoT).
#
# Purpose: a REUSED, cached image the self-hosted Spartan CPU runner
# apptainer-exec's for every CI run, so no per-run dependency install.
# The SIF IS the cache (operator directive 2026-06-16: "container already
# there, reused with caching"). Built once via scitex-container; rebuilt
# (new version) only when the dependency set changes.
#
# Build (canonical — versioned via scitex-container, on a RUNNING compute
# node; never the login node, never sbatch-and-wait):
#   scitex-container apptainer build ci-cpu -o ~/.scitex/dev/containers
# Raw fallback (same effect):
#   apptainer build ci-cpu.sif ci-cpu.def
#
# Run contract (the workflow): each matrix job execs (read-only SIF, no install)
#   apptainer exec --bind <punim> <sif> bash .github/ci/run-in-sif.sh <pyver>
# The baked venvs carry the ecosystem dependency stack INSTALLED — the
# scientific core (numpy/scipy/pandas/matplotlib/xarray/statsmodels/pingouin/
# scikit-learn/torch[cpu]/seaborn/figrecipe), the CLI/MCP stack (click/mcp/
# fastmcp), the notebook-exec tools (nbconvert/ipykernel), the scitex basics
# the per-package suites import (scitex-io/logging/config/dict/decorators/gen/
# nn/stats/str/dsp), scitex-dev[all,dev] (its own console script / entry point
# / metadata), and the pytest toolchain — so per-package `pytest tests/`
# (str/stats/dsp/…) runs with NO per-run install. CI prepends the checkout via
# PYTHONPATH=<co>/src so imports + coverage use the PR code while the baked
# console-script / entry-point / metadata stay available. A dep missing from
# the SIF fails LOUD (rebuild the SIF) — never a silent reinstall.
#
# Why the EXPLICIT UNION (not `scitex[all]`): the umbrella's [all] extra is a
# kitchen sink — it resolves cleanly but drags in tensorflow + jax + opencv +
# playwright + the entire 49-package ecosystem (~494 pkgs, multi-GB SIF) that
# str/stats/dsp never import. The curated union below is ~205 pkgs, no GPU
# torch, no TF/JAX bloat — a lean CPU CI image that still covers every dep the
# matrix suites need. Add a name here when a newly-onboarded package's tests
# need it; rebuild the SIF.
#
# Design notes (vs the heavier agent base.def): no node/rust/claude-sdk —
# CI inside the SIF runs pytest only (checkout/codecov run on the host
# runner). Three Python versions for the required pytest matrix.

Bootstrap: docker
From: ubuntu:24.04

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive

    # System libs: build-essential/pkg-config/libffi/libssl for any
    # source-built wheel; libglib2.0-0 is REQUIRED by scitex.io (without
    # it import silently falls back to "minimal mode" — exactly the kind
    # of silent degradation we forbid). fd for the audit-conformance test.
    #
    # cron + systemd are TEST-ENVIRONMENT tools, not runtime services here:
    # scitex-dev MANAGES crontab + a systemd user unit (`ecosystem cron`,
    # `ecosystem up`), and its tests shell out to `crontab -l` / gate on
    # `shutil.which("systemctl")`. A bare container has neither, so those
    # tests fail with "'crontab' not found" / silently skip the supervisor
    # enable path. Installing the BINARIES (systemd is never PID1 here) makes
    # the CI container match a real SciTeX host — honest, not a mock.
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates curl git locales \
        build-essential pkg-config libffi-dev libssl-dev libglib2.0-0 \
        fd-find ripgrep cron systemd
    locale-gen en_US.UTF-8
    # Debian ships fd as fdfind; the audit helper + muscle memory want `fd`.
    ln -sf "$(command -v fdfind)" /usr/local/bin/fd
    rm -rf /var/lib/apt/lists/*

    # uv (Astral): manages the Python toolchain + fast installs.
    # The installer lands uv in /root/.local/bin (root-only, 0700) — a SYMLINK
    # there is unreadable by the non-root runtime user, so COPY the real
    # binaries to /usr/local/bin (world-exec) for both %post and runtime.
    curl -LsSf https://astral.sh/uv/install.sh | sh
    cp -f /root/.local/bin/uv /usr/local/bin/uv
    cp -f /root/.local/bin/uvx /usr/local/bin/uvx
    chmod 0755 /usr/local/bin/uv /usr/local/bin/uvx
    export PATH=/usr/local/bin:$PATH
    export UV_PYTHON_INSTALL_DIR=/opt/uv-python

    # Pre-stage the three matrix Python versions + a per-version venv with
    # the FULL ecosystem dependency stack FULLY installed (from PyPI) — the
    # scitex umbrella + the deps it misses + scitex-dev[all,dev] are all KEPT
    # installed, not just whatever a single package needs.
    #
    # Why keep scitex-dev baked (vs. installing the checkout at runtime):
    #   * The baked venv is root-owned; a runtime `uv pip install -e .` into it
    #     hits `Permission denied (os error 13)` even with --writable-tmpfs (the
    #     overlay can't copy-up root-owned site-packages for the non-root runner
    #     user). An editable *replace* of a baked copy also hit EOVERFLOW on
    #     gpfs. So NO runtime install — the SIF stays read-only.
    #   * CI runs the CHECKOUT's code by prepending it via PYTHONPATH=<co>/src
    #     (see .github/ci/run-in-sif.sh): PYTHONPATH shadows the baked package
    #     for imports + coverage, while the baked install still provides the
    #     things importlib.metadata-based tooling needs — the `scitex-dev`
    #     console script on PATH (13 skills subprocess tests), the
    #     `console_scripts` ENTRY POINT (audit-cli resolves the CLI via
    #     im.entry_points — a shim with no metadata can't satisfy it), and a
    #     real __version__. ep.load() then imports scitex_dev._cli from the
    #     checkout (PYTHONPATH wins), so audit-cli audits the PR code.
    # ONE resolve per venv bakes everything together (consistent solve, no
    # multi-invocation re-resolution churn). The curated union, by group:
    #   * scientific core — numpy/scipy/pandas/matplotlib/xarray/statsmodels/
    #     pingouin/scikit-learn/torch/seaborn. str imports numpy (+[all]:
    #     matplotlib/pandas/xarray); stats imports numpy/scipy/pandas/
    #     statsmodels/matplotlib/pingouin; dsp imports numpy/scipy/pandas/
    #     matplotlib/torch/xarray.
    #   * CLI / MCP — click, mcp, fastmcp (stats bundles an MCP server; click
    #     drives the `scitex-* <cmd>` CLIs).
    #   * notebook exec — nbconvert + ipykernel (stats [dev] runs example
    #     .ipynb in tests).
    #   * openpyxl — stats [dev]: pandas .to_excel in the _demo_*.py modules +
    #     test_export_results_xlsx (the test_module_demo_runs subprocess demos
    #     and the xlsx export test fail without it).
    #   * scitex basics — the standalone scitex-* deps the suites import:
    #     io/logging/config/dict (str/stats), decorators/gen/nn (dsp). Listing
    #     scitex-dsp/stats/str bakes their PyPI build (metadata + entry points);
    #     the CHECKOUT shadows the code via PYTHONPATH at run time.
    #   * scitex-dev[all,dev] — the dev's own [all]+[dev] extras, so the
    #     `scitex-dev` console script + console_scripts ENTRY POINT +
    #     __version__ stay available for metadata-based tooling (skills
    #     subprocess tests, audit-cli).
    #   * figrecipe — stats[all]/dsp plotting integration tests.
    #   * dsp signal-processing test deps — mne (wavelet path), ripple_detection
    #     (test__detect_ripples preprocessing), and tensorpac (the PAC path +
    #     the 11_modulation_index example notebook, which nbconvert-executes and
    #     hard-imports tensorpac). All three are in scitex-dsp's [dev]/[pac]
    #     extras; without them dsp pytest is 803-pass / 6-fail.
    #   * pytest toolchain — pytest, pytest-cov, pytest-xdist, pytest-timeout
    #     (timeout lags in some PyPI [dev] extras; pin it so the pyproject
    #     `timeout=300` per-test cap is honoured — a hung test fails loud at
    #     300 s instead of wedging the job to timeout-minutes).
    #
    # torch: CPU-ONLY build via uv's --torch-backend=cpu. This is the CPU CI
    # image — the default PyPI `torch` on Linux drags in ~7 nvidia-cu13 wheels
    # (~4 GB). --torch-backend=cpu routes every torch-ecosystem package
    # (torch/torchaudio/…) to the download.pytorch.org/whl/cpu index, keeping
    # the SIF lean. Applied to the whole resolve so transitive torch deps (via
    # scitex-nn/dsp) also stay CPU.
    for V in 3.11 3.12 3.13; do
        uv python install "$V"
        uv venv --python "$V" "/opt/venv-$V"
        uv pip install --python "/opt/venv-$V/bin/python" --torch-backend=cpu \
            numpy scipy pandas matplotlib xarray statsmodels pingouin \
            scikit-learn torch seaborn \
            click mcp fastmcp nbconvert ipykernel openpyxl \
            scitex-io scitex-logging scitex-config scitex-dict \
            scitex-decorators scitex-nn \
            scitex-stats scitex-str scitex-dsp figrecipe \
            mne ripple_detection tensorpac \
            "scitex-dev[all,dev]" \
            pytest pytest-cov pytest-xdist pytest-timeout
    done

%environment
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export UV_PYTHON_INSTALL_DIR=/opt/uv-python
    export PATH=/usr/local/bin:$PATH

%labels
    org.scitex.layer ci-cpu
    org.scitex.runtime apptainer
    org.scitex.contains "python3.11 python3.12 python3.13 uv fd ripgrep cron systemd + numpy scipy pandas matplotlib xarray statsmodels pingouin scikit-learn torch[cpu] seaborn click mcp fastmcp nbconvert ipykernel openpyxl figrecipe mne ripple_detection tensorpac + scitex basics (io logging config dict decorators gen nn stats str dsp) + scitex-dev[all,dev] + pytest{,-cov,-xdist,-timeout}"

%help
    scitex-dev CI runner image (CPU). Reused by the self-hosted Spartan
    runner: apptainer exec --bind <punim> <sif> bash
    .github/ci/run-in-sif.sh <ver> — read-only, no install; the checkout
    is prepended via PYTHONPATH while the baked scitex-dev supplies the
    console script / entry point / metadata. Bakes a curated ecosystem dep
    union (scientific core + CLI/MCP + notebook-exec + scitex basics +
    scitex-dev[all,dev] + pytest), with torch as the CPU-only build, so
    str/stats/dsp/… `pytest tests/` runs without a per-run install. Rebuild via
    scitex-container when the dep set changes.
